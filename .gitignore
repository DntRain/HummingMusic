# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.env
venv/
.venv/
*.egg-info/
dist/
build/

# ──────────────────────────────────────────────
# 模型权重
# ──────────────────────────────────────────────
models/**/*.pt
models/**/*.pth
models/**/*.npy

# ──────────────────────────────────────────────
# 数据集（仅保留目录结构）
# ──────────────────────────────────────────────
data/humming/*
!data/humming/.gitkeep
data/midi_pop/*
!data/midi_pop/.gitkeep
data/midi_jazz/*
!data/midi_jazz/.gitkeep
data/midi_classical/*
!data/midi_classical/.gitkeep
data/midi_folk/*
!data/midi_folk/.gitkeep
data/splits/*
!data/splits/.gitkeep

# ──────────────────────────────────────────────
# 临时文件与实验日志
# ──────────────────────────────────────────────
tmp/*
!tmp/.gitkeep
experiments/*
!experiments/.gitkeep

# ──────────────────────────────────────────────
# 音色库
# ──────────────────────────────────────────────
*.sf2
*.sf3

# ──────────────────────────────────────────────
# 系统文件
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
# IDE
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
